# ── Authentication ────────────────────────────────────────────
# Secret used to sign login tokens. Leave blank to use a built-in dev default
# (fine for local testing). Set a long random value before production —
# generate one with:  python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=
# How long a login stays valid, in minutes (720 = 12 hours).
ACCESS_TOKEN_EXPIRE_MINUTES=720

# ── One Step GPS ──────────────────────────────────────────────
# Leave ONESTEP_API_KEY blank to run in MOCK mode (trucks simulate movement,
# so you can build and test the whole app before your API key arrives).
# Paste the key One Step GPS sends you here to switch to live tracking.
ONESTEP_API_KEY=
# Base URL — adjust to match the docs One Step GPS sends you.
ONESTEP_API_BASE=https://track.onestepgps.com/v3/api/public
# How often (seconds) to refresh truck positions.
GPS_POLL_SECONDS=10

# ── QuickBooks Online A/R sync ────────────────────────────────
# Leave these blank to run billing in MOCK mode (serves the local invoice table,
# so the billing screen works before QuickBooks is connected). Fill ALL FOUR to
# switch to LIVE sync — the backend then pulls each customer's invoices from
# QuickBooks on a schedule. Get them from https://developer.intuit.com:
#   CLIENT_ID/SECRET from your app; REFRESH_TOKEN + REALM_ID from running the
#   OAuth consent flow once for your company. See integrations/quickbooks.py.
QBO_CLIENT_ID=
QBO_CLIENT_SECRET=
QBO_REFRESH_TOKEN=
QBO_REALM_ID=
# "production" for real company data, or "sandbox" for Intuit's test company.
QBO_ENVIRONMENT=production
# How often (seconds) to re-pull A/R from QuickBooks. 900 = 15 minutes.
QBO_SYNC_SECONDS=900
